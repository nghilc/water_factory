    </div>
    <!-- /.content-header -->

    <!-- Main content -->
    <section class="content">
      <div class="container-fluid">      
        <!-- Main row -->
         <div class="row mb-1 d-flex flex-wrap align-items-end sticky-div ">
            <div class="col-lg-3 col-md-3 col-6">
              <div class="form-group">
                <label for="">Đơn vị quản lý:</label>
                <select class="form-control selectpicker" data-live-search="true" id="filter_danhsachtram" required autocomplete="off"
                  data-dropup-auto="false" data-container="body">
                  <option value="all" dv_type="all">Các đơn vị quản lý
                  </option>
                
                  <% // Lọc ra các nhóm chính 
                  const groups=danh_sach_xi_nghiep_nha_may.filter(item=> item.parent_id === null);
                
                    groups.forEach(group => {
                    // Tìm các trạm con có donviquanly_id = id của nhóm chính
                    const subItems = danh_sach_xi_nghiep_nha_may.filter(item => item.parent_id === group.org_id);
                    %>
                    <!-- Nhóm chính -->
                    <option value="<%= group.org_id %>" dv_type="xi_nghiep" style="font-weight: bold;">
                      <%= group.name %>
                    </option>
                
                    <!-- Các trạm con -->
                    <% subItems.forEach(tram=> { %>
                      <option value="<%= tram.org_id %>" dv_type="nha_may">&nbsp;&nbsp;&nbsp;<%= tram.name %>
                      </option>
                      <% }); %>
                
                        <% }); %>
                </select>
              </div>

            </div>
            <div class="col-lg-3 col-md-3 col-6">
                <div class="form-group">
                    <label for="" >Tên trạm:</label>
                    <select class="form-control selectpicker" required id="filter_meter" data-live-search="true">
                            <option  data-tokens="" MeterCode = "" NodeCode=""></option>
                    </select>
                </div>
            </div>
            <div class="col-lg-3 col-md-3 col-6">
              <div class="form-group">
                  <label for="" >Mã trạm:</label>
                  <input class="form-control" readonly id="Metercode_read" value="">
              </div>
          </div>

         </div>
        <div class="row" id="meter_info_container">
            <%- include('../partials/setting_info') %>
          <!-- right col -->
        </div>
        <!-- /.row (main row) -->
      </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
