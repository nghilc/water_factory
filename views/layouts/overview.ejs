                        </tr>
                      </thead>
                      <tbody id="danhsachtram_body">
                        <% for(let i=0; i < danh_sach_thiet_bị.length; i++){ %>
                          <tr MeterCode="<%= danh_sach_thiet_bị[i].MeterCode%>"
                            NodeCode="<%= danh_sach_thiet_bị[i].NodeCode %>"
                            meter_name="<%= danh_sach_thiet_bị[i].meter_name %>"
                            meter_status="<%= danh_sach_thiet_bị[i].status_meter%>"
                            data_type="<%= danh_sach_thiet_bị[i].data_type%>">
                            <!-- <td class="text-center"><%= i+1 %></td> -->
                            <td class="text-left">
                              <%= danh_sach_thiet_bị[i].meter_name%>
                            </td>
                            <% if(danh_sach_thiet_bị[i].status_meter==2){ %>
                              <td class="text-center" meter_status="<%= danh_sach_thiet_bị[i].status_meter%>"><span><i
