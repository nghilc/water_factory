                    <!-- Cảnh báo chất lượng -->
                    <div class="alert-panel water-quality-card">
                      <h5>✅ TRẠNG THÁI CHẤT LƯỢNG</h5>
                      <div class="alert-item alert-low">
                        <div class="alert-icon">🟢</div>
                        <div class="alert-content">
                          <div class="alert-title">Chất lượng nước thô ổn định</div>
