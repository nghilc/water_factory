                        <div class="devices-count"><span id="he_thong_giam_sat"></span> hệ thống giám sát</div>
                      </div>
                    </div>

                    <!-- Thống kê tổng quan -->
                    <div class="stats-grid">
                      <div class="stat-card-large">
                        <div class="d-flex align-items-center">
                          <div class="stat-icon-large">🌊</div>
                          <div class="stat-label-large">CHẤT LƯỢNG NƯỚC THÔ</div>
                        </div>
                        <div class="stat-value-large font-weight-bold text-success" id="chat_luong_nuoc_tho">...</div>
                      </div>
                      <div class="stat-card-large">
                        <div class="d-flex align-items-center">
                          <div class="stat-icon-large">💧</div>
                          <div class="stat-label-large">CHẤT LƯỢNG NƯỚC SẠCH</div>
                        </div>
                        <div class="stat-value-large text-success font-weight-bold" id="chat_luong_nuoc_sach">TUYỆT VỜI
                        </div>
                      </div>
                      <div class="stat-card-large">
                        <div class="d-flex align-items-center">
                          <div class="stat-icon-large">⚡</div>
