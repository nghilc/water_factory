            </div>
            <div class="modal-footer">
              <button class="btn btn-info" onclick="resetStandards()">Đặt lại mặc định</button>
              <button class="btn btn-success" onclick="saveStandards()">Lưu cài đặt</button>
            </div>
          </div>
