        <div class="spinner-border text-primary" role="status"></div>
        <span>Đang tải dữ liệu...</span>
      </div>
      <div id="notification" class="text-center"></div>

      <!-- Popup cảnh báo -->
      <div id="alert-container" style=" font-size: small;"></div>

